{
  "name": "api",
  "private": true,
  "type": "commonjs",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "node --import tsx --test src/game-session/game-session.repository.spec.ts src/game-session/game-state-machine.spec.ts src/rooms/rooms.controller.spec.ts",
    "test:auth": "node --import tsx --test src/auth/auth.service.spec.ts",
    "test:game-event": "node --import tsx --test src/game-events/game-event-log.model.spec.ts",
    "test:game-event-flow": "node --import tsx --test src/realtime/realtime.game-events.spec.ts",
    "test:game-event-recorder": "node --import tsx --test src/game-events/game-event-recorder.service.spec.ts",
    "test:game-event-timeline": "node --import tsx --test src/game-events/game-events.controller.spec.ts",
    "test:game-session-redis": "node --import tsx --test src/game-session/redis-game-session.repository.spec.ts",
    "test:room-redis": "node --import tsx --test src/rooms/redis-room.repository.spec.ts",
    "test:game-session-module": "node --import tsx --test src/game-session/game-session.module.spec.ts",
    "test:game-session-disconnect": "node --import tsx --test src/game-session/game-session.disconnect.spec.ts",
    "test:game-session-reconnect": "node --import tsx --test src/game-session/game-session.reconnect.spec.ts",
    "test:game-rules": "node --import tsx --test src/game-session/game-rules.service.spec.ts",
    "test:game-e2e": "node --import tsx --test src/realtime/realtime.game-flow.e2e-spec.ts",
    "test:game-session": "node --import tsx --test src/game-session/game-session.repository.spec.ts",
    "test:game-command-lock": "node --import tsx --test src/realtime/game-command-lock.service.spec.ts",
    "test:chat-cache": "node --import tsx --test src/realtime/chat-message-cache.service.spec.ts",
    "test:connection-state": "node --import tsx --test src/realtime/connection-state.service.spec.ts",
    "test:available-actions": "node --import tsx --test src/realtime/available-actions.service.spec.ts",
    "test:personal-event-channel": "node --import tsx --test src/realtime/personal-event-channel.service.spec.ts",
    "test:command-errors": "node --import tsx --test src/game-commands/game-command.errors.spec.ts",
    "test:command-envelope": "node --import tsx --test src/realtime/command-envelope.spec.ts",
    "test:reconnect-state": "node --import tsx --test src/realtime/reconnect-state.service.spec.ts",
    "test:reconnect-idempotency-lock": "node --import tsx --test src/realtime/realtime.reconnect-idempotency-lock.spec.ts",
    "test:request-idempotency": "node --import tsx --test src/realtime/request-idempotency.service.spec.ts",
    "test:multi-instance": "node --import tsx --test src/rooms/rooms.multi-instance.spec.ts src/realtime/realtime.multi-instance.spec.ts",
    "test:socket-redis-adapter": "node --import tsx --test src/realtime/realtime.multi-instance.spec.ts",
    "test:redis": "node --import tsx --test src/redis/redis.service.spec.ts",
    "test:socket": "node --import tsx --test src/realtime/realtime.gateway.spec.ts",
    "test:user-repository": "node --import tsx --test src/users/user.repository.spec.ts",
    "test:integration": "pnpm run test:auth && pnpm run test:user-repository && pnpm run test:redis && pnpm run test:game-event && pnpm run test:game-event-recorder && pnpm run test:game-event-timeline && pnpm run test:socket",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@mafia-casefile/shared": "workspace:*",
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/platform-socket.io": "latest",
    "@nestjs/websockets": "latest",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "latest",
    "dotenv": "latest",
    "ioredis": "latest",
    "jsonwebtoken": "latest",
    "pg": "latest",
    "prisma": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
