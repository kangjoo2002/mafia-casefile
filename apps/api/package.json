{
  "name": "api",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "node --import tsx --test src/game-session/game-session.repository.spec.ts src/game-session/game-state-machine.spec.ts src/rooms/rooms.controller.spec.ts",
    "test:auth": "node --import tsx --test src/auth/auth.service.spec.ts",
    "test:game-event": "node --import tsx --test src/game-events/game-event-log.model.spec.ts",
    "test:game-event-recorder": "node --import tsx --test src/game-events/game-event-recorder.service.spec.ts",
    "test:game-event-timeline": "node --import tsx --test src/game-events/game-events.controller.spec.ts",
    "test:game-session-redis": "node --import tsx --test src/game-session/redis-game-session.repository.spec.ts",
    "test:game-session-module": "node --import tsx --test src/game-session/game-session.module.spec.ts",
    "test:game-e2e": "node --import tsx --test src/realtime/realtime.game-flow.e2e-spec.ts",
    "test:game-session": "node --import tsx --test src/game-session/game-session.repository.spec.ts",
    "test:redis": "node --import tsx --test src/redis/redis.service.spec.ts",
    "test:socket": "node --import tsx --test src/realtime/realtime.gateway.spec.ts",
    "test:user-repository": "node --import tsx --test src/users/user.repository.spec.ts",
    "test:integration": "pnpm run test:auth && pnpm run test:user-repository && pnpm run test:redis && pnpm run test:game-event && pnpm run test:game-event-recorder && pnpm run test:game-event-timeline && pnpm run test:socket",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@mafia-casefile/shared": "workspace:*",
    "@nestjs/common": "latest",
    "@nestjs/core": "latest",
    "@nestjs/platform-express": "latest",
    "@nestjs/platform-socket.io": "latest",
    "@nestjs/websockets": "latest",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "bcryptjs": "latest",
    "ioredis": "latest",
    "jsonwebtoken": "latest",
    "pg": "latest",
    "reflect-metadata": "latest",
    "rxjs": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/pg": "latest",
    "dotenv": "latest",
    "prisma": "latest",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
